{
  "manifest_version": 3,
  "name": "Favs Panel",
  "version": "1.0.0",
  "description": "Panel detallado para explorar todos tus favoritos: árbol de carpetas, búsqueda y metadata.",
  "permissions": ["bookmarks", "favicon"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Favs Panel"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Abrir Favs Panel"
    }
  }
}
